<UserControl x:Class="MarvinsAIRARefactoredSimHub.PluginControl" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:MarvinsAIRARefactoredSimHub" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:styles="clr-namespace:SimHub.Plugins.Styles;assembly=SimHub.Plugins" xmlns:ui="clr-namespace:SimHub.Plugins.UI;assembly=SimHub.Plugins" mc:Ignorable="d">
    <DockPanel>
        <styles:SHStatusBar DockPanel.Dock="Bottom">
            Plugin Status: 
            <TextBlock Text="{Binding MairaStatus}"/>
            <TextBlock Text=" "/>
            <styles:SHStatusBarSeparator></styles:SHStatusBarSeparator>
            Plugin Properties Version: 
            <TextBlock Text="{Binding PluginPropertiesVersion}"/>
            <TextBlock Text=" "/>
            <styles:SHStatusBarSeparator></styles:SHStatusBarSeparator>
			MAIRA Properties Version: 
	        <TextBlock Text="{Binding MairaPropertiesVersion}"/>
            <TextBlock Text=" "/>
        </styles:SHStatusBar>
        <ScrollViewer>
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition />
					<ColumnDefinition Width="0*" />
				</Grid.ColumnDefinitions>
				<styles:SHSection Title="Display Options for Compatible Overlays" Grid.ColumnSpan="2" ShowSeparator="True">
					<StackPanel>
						<styles:SHToggleCheckbox x:Name="overlaysShowInPracticeCheckbox">
							Show overlays in Practice sessions
						</styles:SHToggleCheckbox>
						<styles:SHToggleCheckbox  x:Name="overlaysShowInQualifyingCheckbox">
							Show overlays in Qualifying sessions
						</styles:SHToggleCheckbox>
						<styles:SHToggleCheckbox x:Name="overlaysShowInRaceCheckbox">
							Show overlays in Race sessions
						</styles:SHToggleCheckbox>
						<styles:SHToggleCheckbox x:Name="overlaysShowInTestDriveCheckbox">
							Show overlays in Test Drive sessions
						</styles:SHToggleCheckbox>
					</StackPanel>
				</styles:SHSection>
			</Grid>
		</ScrollViewer>
    </DockPanel>
</UserControl>